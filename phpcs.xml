<?xml version="1.0"?>
<ruleset name="OpenSparrow Standard">
    <description>The coding standard for OpenSparrow.</description>

    <arg name="extensions" value="php"/>

    <rule ref="PSR-12"/>

    <file>.</file>

    <exclude-pattern>*/assets/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>

    <exclude-pattern>*tmp_*</exclude-pattern>

    <arg value="p"/>
    <arg value="colors"/>
</ruleset>